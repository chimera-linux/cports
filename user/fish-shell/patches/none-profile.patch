From 588bb97924c93f98ed567b92ee9fedd549b89eaf Mon Sep 17 00:00:00 2001
From: Ayush Agarwal <ayush@ayushnix.com>
Date: Fri, 2 Jan 2026 06:59:03 +0530
Subject: [PATCH] build with cargo-auditable and set none profile

---
 CMakeLists.txt | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index c65b3e422..f9099c12b 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -57,18 +57,18 @@ if(NOT "${CMAKE_BUILD_TYPE}" IN_LIST build_types)
 endif()
 
 add_custom_target(
   fish ALL
   COMMAND
     "${CMAKE_COMMAND}" -E
       env ${VARS_FOR_CARGO}
         ${Rust_CARGO}
-          build --bin fish
-          $<$<CONFIG:Release>:--release>
+          auditable build --bin fish
+          $<$<CONFIG:None>:--release>
           $<$<CONFIG:RelWithDebInfo>:--profile=release-with-debug>
           --target ${Rust_CARGO_TARGET}
           --no-default-features
           --features=${FISH_CARGO_FEATURES}
           ${CARGO_FLAGS}
     &&
     "${CMAKE_COMMAND}" -E
       copy "${rust_target_dir}/${rust_profile}/fish" "${CMAKE_CURRENT_BINARY_DIR}"
-- 
2.52.0

