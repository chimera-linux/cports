             let seconds = self.0.st_ctim.tv_sec;
 
-            #[cfg(not(any(
-                target_os = "aix",
-                target_os = "hurd",
-                all(target_arch = "loongarch64", target_env = "musl")
-            )))]
+            #[cfg(not(any(target_os = "aix", target_os = "hurd")))]
             let nanoseconds = self.0.st_ctime_nsec;
-            #[cfg(any(
-                target_os = "aix",
-                target_os = "hurd",
-                all(target_arch = "loongarch64", target_env = "musl")
-            ))]
+            #[cfg(any(target_os = "aix", target_os = "hurd"))]
