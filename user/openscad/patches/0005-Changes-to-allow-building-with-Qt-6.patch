+#if QT_VERSION < QT_VERSION_CHECK(6, 0, 0)
 	writer.setCodec("UTF-8");
+#endif
 	writer << edt->toPlainText();
 	writer.flush();
 	bool saveOk = writer.status() == QTextStream::Ok;
