From: Chris Mayo <aklhfex@gmail.com>
Date: Wed, 27 Dec 2023 17:20:21 +0000
Subject: [PATCH 05/13] Changes to allow building with Qt 6

With Qt5Compat and without gamepad support.
---
 src/MainWindow.h                         |  3 +++
 src/Preferences.cc                       |  5 ++++-
 src/mainwin.cc                           |  9 ++++++---
 src/parameter/parametervirtualwidget.cpp |  3 ++-
 src/scintillaeditor.cpp                  | 13 +++++++------
 src/tabmanager.cc                        |  4 ++++
 6 files changed, 26 insertions(+), 11 deletions(-)

diff --git a/src/MainWindow.h b/src/MainWindow.h
index 429e74655..3fdd13594 100644
--- a/src/MainWindow.h
+++ b/src/MainWindow.h
@@ -16,6 +16,7 @@
 #include <vector>
 #include <QMutex>
 #include <QElapsedTimer>
+#include <QSoundEffect>
 #include <QTime>
 #include <QIODevice>
 #include "input/InputDriver.h"
@@ -345,6 +346,8 @@ private:
 	int last_parser_error_pos; // last highlighted error position
 	int tabCount = 0;
 
+	QSoundEffect *renderCompleteSoundEffect;
+
 signals:
 	void highlightError(int);
 	void unhighlightLastError();
diff --git a/src/Preferences.cc b/src/Preferences.cc
index 434e3a1f7..8b0a123c5 100644
--- a/src/Preferences.cc
+++ b/src/Preferences.cc
@@ -26,9 +26,12 @@
 
 #include "Preferences.h"
 
+#include <QActionGroup>
 #include <QMessageBox>
