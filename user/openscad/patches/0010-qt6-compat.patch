diff --git a/src/scintillaeditor.cpp b/src/scintillaeditor.cpp
index 03ece8e06..fa15612ae 100755
--- a/src/scintillaeditor.cpp
+++ b/src/scintillaeditor.cpp
@@ -1027,7 +1027,7 @@ bool ScintillaEditor::handleWheelEventNavigateNumber (QWheelEvent *wheelEvent)
 	 {
 		if (!wasChanged) qsci->beginUndoAction();
 
-		if (wheelEvent->delta() < 0)
+		if (wheelEvent->angleDelta().y() < 0)
 		{
 			if (modifyNumber(Qt::Key_Down)) 
 			{
@@ -1037,7 +1037,7 @@ bool ScintillaEditor::handleWheelEventNavigateNumber (QWheelEvent *wheelEvent)
 		}
 		else
 		{
-			// wheelEvent->delta() > 0
+			// wheelEvent->angleDelta().y() > 0
 			if (modifyNumber(Qt::Key_Up))
 			{
 				wasChanged = true;
@@ -1057,7 +1057,7 @@ bool ScintillaEditor::handleWheelEventNavigateNumber (QWheelEvent *wheelEvent)
 		auto *cmd = qsci->standardCommands()->boundTo(k);
 		if (cmd && (cmd->command() == QsciCommand::Undo || cmd->command() == QsciCommand::Redo))
 			QTimer::singleShot(0, this, SIGNAL(previewRequest()));
-		else if (cmd || wheelEvent->delta())
+		else if (cmd || wheelEvent->angleDelta().y())
 		{
 			// any insert or command (but not undo/redo) cancels the preview after undo
 			previewAfterUndo = false;
@@ -1113,11 +1113,12 @@ bool ScintillaEditor::modifyNumber(int key)
 	qsci->SendScintilla(QsciScintilla::SCI_SETEMPTYSELECTION);
 	qsci->setCursorPosition(line, index);
 
-	auto begin=QRegExp("[-+]?\\d*\\.?\\d*$").indexIn(text.left(index));
+	auto match=QRegularExpression("[-+]?\\d*\\.?\\d*$").match(text.left(index));
+	auto begin=match.hasMatch() ? match.capturedStart() : -1;
 
-	QRegExp rx("[_a-zA-Z]");
+	QRegularExpression rx("\\A[_a-zA-Z]\\z");
 	auto check = text.mid(begin-1,1);
-	if(rx.exactMatch(check)) return false;
+	if(rx.match(check).hasMatch()) return false;
 
 	auto end=text.indexOf(QRegularExpression("[^0-9.]"),index);
 	if (end<0) end=text.length();
