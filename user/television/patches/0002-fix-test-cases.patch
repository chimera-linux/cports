Subject: [PATCH 2/3] fix test cases

---
 tests/cli/ui.rs | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/tests/cli/ui.rs b/tests/cli/ui.rs
index 67a0617..269ec3f 100644
--- a/tests/cli/ui.rs
+++ b/tests/cli/ui.rs
@@ -433,7 +433,7 @@ fn test_no_preview_disables_preview_panel() {
     tester.send("o"); // Toggle preview key
 
     // Verify no preview elements are shown (no scrollbar, no panel frame)
-    tester.assert_tui_frame_contains_none(&["───╮╭───", "Show Preview"]);
+    tester.assert_tui_frame_contains_none(&["─╮╭─", "Show Preview"]);
 
     // Send Ctrl+C to exit
     tester.send(&ctrl('c'));
@@ -451,7 +451,7 @@ fn test_show_preview_starts_with_preview_visible() {
     let mut child = tester.spawn_command_tui(cmd);
 
     // Verify preview panel is initially visible (landscape layout shows side-by-side panels)
-    tester.assert_tui_frame_contains_all(&["───╮╭───", "Hide Preview"]);
+    tester.assert_tui_frame_contains_all(&["─╮╭─", "Hide Preview"]);
 
     // Send Ctrl+C to exit
     tester.send(&ctrl('c'));
@@ -507,7 +507,7 @@ fn test_hide_preview_scrollbar_hides_scrollbar() {
     let mut child = tester.spawn_command_tui(cmd);
 
     // The preview panel should still be visible but without scrollbar indicators
-    tester.assert_tui_frame_contains_all(&["Hide Preview", "───╮╭───"]);
+    tester.assert_tui_frame_contains_all(&["Hide Preview", "─╮╭─"]);
     tester.assert_not_tui_frame_contains("▲");
 
     // Send Ctrl+C to exit
