From 51d8dcb90a2df486612a684abf75efdb65b66170 Mon Sep 17 00:00:00 2001
From: q66 <q66@chimera-linux.org>
Date: Fri, 13 Mar 2026 15:27:57 +0100
Subject: [PATCH] Selectively downgrade some crates in cargo

Until we can figure out why it's busted on ppc64le, downgrade
some dependencies until things no longer crash. This is not
sustainable forever but for now it makes it work.
---
 Cargo.lock | 13 +++++++------
 Cargo.toml |  6 +++---
 2 files changed, 10 insertions(+), 9 deletions(-)

diff --git a/Cargo.lock b/Cargo.lock
index f7727ec..46e92ca 100644
--- a/Cargo.lock
+++ b/Cargo.lock
@@ -132,9 +132,9 @@ dependencies = [
 
 [[package]]
 name = "anyhow"
-version = "1.0.100"
+version = "1.0.75"
 source = "registry+https://github.com/rust-lang/crates.io-index"
-checksum = "a23eb6b1614318a8071c9b2521f36b424b2c83db5eb3a0fead4a6c0809af6e61"
+checksum = "a4668cab20f66d8d020e1fbc0ebe47217433c1b6c8f2040faf858554e394ace6"
 
 [[package]]
 name = "arc-swap"
@@ -2560,16 +2560,17 @@ dependencies = [
 
 [[package]]
 name = "ignore"
-version = "0.4.25"
+version = "0.4.20"
 source = "registry+https://github.com/rust-lang/crates.io-index"
-checksum = "d3d782a365a015e0f5c04902246139249abf769125006fbe7649e2ee88169b4a"
+checksum = "dbe7873dab538a9a44ad79ede1faf5f30d49f9a5c883ddbab48bce81b64b7492"
 dependencies = [
- "crossbeam-deque",
  "globset",
+ "lazy_static",
  "log",
  "memchr",
- "regex-automata",
+ "regex",
  "same-file",
+ "thread_local",
  "walkdir",
  "winapi-util",
 ]
diff --git a/Cargo.toml b/Cargo.toml
index 392758a..de88199 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -21,7 +21,7 @@ repository = "https://github.com/rust-lang/cargo"
 annotate-snippets = { version = "0.12.10", features = ["simd"] }
 anstream = "0.6.21"
 anstyle = "1.0.13"
-anyhow = "1.0.100"
+anyhow = "1.0.75"
 base64 = "0.22.1"
 blake3 = "1.8.2"
 build-rs = { version = "0.3.1", path = "crates/build-rs" }
@@ -58,7 +58,7 @@ hex = "0.4.3"
 hmac = "0.12.1"
 home = "0.5.12"
 http-auth = { version = "0.1.10", default-features = false }
-ignore = "0.4.25"
+ignore = "0.4.20"
 im-rc = "15.1.0"
 indexmap = "2.12.1"
 itertools = "0.14.0"
@@ -67,7 +67,7 @@ jobserver = "0.1.34"
 libc = "0.2.178"
 libgit2-sys = "0.18.3"
 libloading = "0.9.0"
-memchr = "2.7.6"
+memchr = "2.6.0"
 memfd = "0.6.5"
 miow = "0.6.1"
 opener = "0.8.3"
-- 
2.52.0

