Author: q66 <q66@chimera-linux.org>
Date:   Fri May 15 15:50:44 2026 +0200

    eliminate xorg session from being visible
    
    We still need the SM stuff for non-systemd gnome-shell interactions
    but don't try to pretend that gnome on xorg is still a thing.

diff --git a/data/meson.build b/data/meson.build
index bd66ff0..d451543 100644
--- a/data/meson.build
+++ b/data/meson.build
@@ -4,9 +4,6 @@ desktops = [
   desktop_plain,
   'gnome-wayland',
 ]
-if have_x11
-  desktops += ['gnome-xorg']
-endif
 
 shell_component = {
   desktop_plain: 'org.gnome.Shell',
@@ -49,9 +46,7 @@ foreach name: desktops
     configuration: desktop_conf
   )
 
-  if name.endswith('-xorg') and have_x11
-    install_dir = session_datadir / 'xsessions'
-  elif name.endswith('-wayland')
+  if name.endswith('-wayland')
     install_dir = session_datadir / 'wayland-sessions'
   else
     # FIXME: The same target can not be copied into two directories.
