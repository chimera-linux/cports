+        /* chimera active ttys */
+        QFile ttys{QString::fromUtf8("/run/agetty-active")};
+        if (ttys.open(QIODevice::ReadOnly)) {
+            char buf[4096], *bufp = buf, *ttystr = nullptr;
+            memset(buf, 0, sizeof(buf));
+            auto sz = ttys.read(buf, sizeof(buf) - 1);
