+                        break;
+                    }
+                    if (gettyn >= minvt) {
+                        ttystr = bufp;
+                        minvt = gettyn + 1;
+                    }
+                    if (!*err) {
+                        break;
+                    }
+                    *err = '\0';
+                    bufp = err + 1;
+                }
+                if (minvt < 64 && ttystr && !isTtyInUse(QString::fromUtf8(ttystr))) {
+                    return int(minvt);
+                }
+            }
+        }
+        if (!isTtyInUse(QStringLiteral("tty%1").arg(SDDM_INITIAL_VT))) {
             return SDDM_INITIAL_VT;
