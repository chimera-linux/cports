From ce528844bd71632f020075b89396ae25e35e0492 Mon Sep 17 00:00:00 2001
From: LN Liberda <lauren@selfisekai.rocks>
Date: Mon, 20 Apr 2026 17:21:08 +0200
Subject: [PATCH] Fix bytemuck with Rust 1.95

A date being specified implies it's for nightly only. Since the change landed
in stable 1.95 now, we need a version specified here.
---
 .../rust/chromium_crates_io/vendor/bytemuck-v1/src/pod.rs     | 4 ++--
 .../chromium_crates_io/vendor/bytemuck-v1/src/zeroable.rs     | 4 ++--
 2 files changed, 4 insertions(+), 4 deletions(-)

diff --git a/third_party/rust/chromium_crates_io/vendor/bytemuck-v1/src/pod.rs b/third_party/rust/chromium_crates_io/vendor/bytemuck-v1/src/pod.rs
index 330f722b3419b..c8a87b5bb12ec 100644
--- a/third_party/rust/chromium_crates_io/vendor/bytemuck-v1/src/pod.rs
+++ b/third_party/rust/chromium_crates_io/vendor/bytemuck-v1/src/pod.rs
@@ -143,7 +143,7 @@ impl_unsafe_marker_for_simd!(
   }
 );
 
-#[rustversion::before(2026-01-27)] // See https://github.com/Lokathor/bytemuck/issues/343
+#[rustversion::before(1.95)] // See https://github.com/Lokathor/bytemuck/issues/343
 #[cfg(feature = "nightly_portable_simd")]
 #[cfg_attr(
   feature = "nightly_docs",
@@ -156,7 +156,7 @@ where
 {
 }
 
-#[rustversion::since(2026-01-27)] // See https://github.com/Lokathor/bytemuck/issues/343
+#[rustversion::since(1.95)] // See https://github.com/Lokathor/bytemuck/issues/343
 #[cfg(feature = "nightly_portable_simd")]
 #[cfg_attr(
   feature = "nightly_docs",
