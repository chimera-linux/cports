index 186c567fffddb..7b8c438991f28 100644
--- a/third_party/rust/chromium_crates_io/vendor/bytemuck-v1/src/zeroable.rs
+++ b/third_party/rust/chromium_crates_io/vendor/bytemuck-v1/src/zeroable.rs
@@ -222,7 +222,7 @@ impl_unsafe_marker_for_simd!(
     }
 );
 
-#[rustversion::before(2026-01-27)] // See https://github.com/Lokathor/bytemuck/issues/343
+#[rustversion::before(1.95)] // See https://github.com/Lokathor/bytemuck/issues/343
