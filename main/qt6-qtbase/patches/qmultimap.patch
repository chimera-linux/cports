    QMultiMap: fix compliance with the C++ standard
    
    The .find() method is not required to return an iterator to the
    most recently inserted item while the Qt documentation requires
    so. Do the correct thing according to C++.

diff --git a/src/corelib/tools/qmap.h b/src/corelib/tools/qmap.h
index 9080f99..58bc306 100644
--- a/src/corelib/tools/qmap.h
+++ b/src/corelib/tools/qmap.h
@@ -1210,24 +1210,23 @@ public:
             return T();
 
         if (d.isShared()) {
-            auto i = d->m.find(key);
-            const auto hold = referenceHoldingDetachExceptFor(i);
-            return i->second;
+            auto r = d->m.equal_range(key);
+            const auto hold = referenceHoldingDetachExceptFor((r.first == r.second) ? d->m.end() : r.first);
+            return r.first->second;
         }
 
+        auto r = d->m.equal_range(key);
+        if (r.first == r.second)
+            return T();
+
 #ifdef __cpp_lib_node_extract
-        if (const auto node = d->m.extract(key))
-            return std::move(node.mapped());
+        return std::move(d->m.extract(r.first).mapped());
 #else
-        auto i = d->m.find(key);
-        if (i != d->m.end()) {
-            // ### breaks RVO on most compilers (but only on old-fashioned ones, so who cares?)
-            T result(std::move(i->second));
-            d->m.erase(i);
-            return result;
-        }
+        // ### breaks RVO on most compilers (but only on old-fashioned ones, so who cares?)
+        T result(std::move(r.first->second));
+        d->m.erase(r.first);
+        return result;
 #endif
-        return T();
     }
 
     bool contains(const Key &key) const
@@ -1255,9 +1254,9 @@ public:
     {
         if (!d)
             return defaultValue;
-        const auto i = d->m.find(key);
-        if (i != d->m.cend())
-            return i->second;
+        auto r = d->m.equal_range(key);
+        if (r.first != r.second)
+            return r.first->second;
         return defaultValue;
     }
 
@@ -1559,14 +1558,20 @@ public:
     iterator find(const Key &key)
     {
         const auto hold = referenceHoldingDetach();
-        return iterator(d->m.find(key));
+        auto r = d->m.equal_range(key);
+        if (r.first != r.second)
+            return iterator(r.first);
+        return iterator(d->m.end());
     }
 
     const_iterator find(const Key &key) const
     {
         if (!d)
             return const_iterator();
-        return const_iterator(d->m.find(key));
+        auto r = d->m.equal_range(key);
+        if (r.first != r.second)
+            return const_iterator(r.first);
+        return const_iterator(d->m.cend());
     }
 
     const_iterator constFind(const Key &key) const
@@ -1687,20 +1692,20 @@ public:
             d.reset(new MapData);
             return iterator(d->m.insert({ key, value }));
         }
-        auto i = d->m.find(key);
+        auto r = d->m.equal_range(key);
+
         if (d.isShared()) {
-            const auto hold = referenceHoldingDetachExceptFor(i);
+            const auto hold = referenceHoldingDetachExceptFor((r.first == r.second) ? d->m.end() : r.first);
             return iterator(d->m.insert({ key, value }));
         }
 
         // Similarly, improve here (e.g. lower_bound and hinted insert);
         // there's no insert_or_assign on multimaps
-        if (i != d->m.end())
-            i->second = value;
-        else
-            i = d->m.insert({key, value});
+        if (r.first == r.second)
+            return iterator(d->m.insert({ key, value }));
 
-        return iterator(i);
+        r.first->second = value;
+        return iterator(r.first);
     }
 
     // STL compatibility
