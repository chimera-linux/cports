         detach();
 
         size_type result = 0;
-        const auto &keyCompare = d->m.key_comp();
 
-        auto i = d->m.find(keyCopy);
-        const auto e = d->m.end();
+        auto r = d->m.equal_range(keyCopy);
+        auto i = r.first;
 
-        while (i != e && !keyCompare(keyCopy, i->first)) {
+        while (i != r.second) {
             if (i->second == valueCopy) {
                 i = d->m.erase(i);
                 ++result;
@@ -1045,19 +1044,18 @@ public:
         // elements (the one to be removed can be skipped).
         detach();
 
+        auto r = d->m.equal_range(key);
+        if (r.first == r.second)
+            return T();
+
 #ifdef __cpp_lib_node_extract
-        if (const auto node = d->m.extract(key))
-            return std::move(node.mapped());
+        return std::move(d->m.extract(r.first).mapped());
 #else
-        auto i = d->m.find(key);
-        if (i != d->m.end()) {
-            // ### breaks RVO on most compilers (but only on old-fashioned ones, so who cares?)
-            T result(std::move(i->second));
-            d->m.erase(i);
-            return result;
-        }
+        // ### breaks RVO on most compilers (but only on old-fashioned ones, so who cares?)
+        T result(std::move(i->second));
+        d->m.erase(i);
+        return result;
 #endif
-        return T();
     }
 
     bool contains(const Key &key) const
@@ -1085,9 +1083,9 @@ public:
     {
         if (!d)
             return defaultValue;
-        const auto i = d->m.find(key);
