From bf9eea7f11054ac43b0bd6f7f345117c1d7811f1 Mon Sep 17 00:00:00 2001
From: q66 <q66@chimera-linux.org>
Date: Fri, 29 Nov 2024 19:46:27 +0100
Subject: [PATCH 22/28] clang: error when using ifunc attribute on unsupported
 targets

---
 clang/lib/Sema/SemaDeclAttr.cpp | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/clang/lib/Sema/SemaDeclAttr.cpp b/clang/lib/Sema/SemaDeclAttr.cpp
index 3f0ea5c8f..b8a97951f 100644
--- a/clang/lib/Sema/SemaDeclAttr.cpp
+++ b/clang/lib/Sema/SemaDeclAttr.cpp
@@ -1692,6 +1692,13 @@ static void handleIFuncAttr(Sema &S, Decl *D, const ParsedAttr &AL) {
     return;
   }
 
+  // Unsupported targets should raise a diagnostic error.
+  if (!S.Context.getTargetInfo().supportsIFunc()) {
+    S.Diag(AL.getLoc(), diag::err_keyword_not_supported_on_target)
+      << AL << AL.getRange();
+    return;
+  }
+
   markUsedForAliasOrIfunc(S, D, AL, Str);
   D->addAttr(::new (S.Context) IFuncAttr(S.Context, AL, Str));
 }
-- 
2.52.0

