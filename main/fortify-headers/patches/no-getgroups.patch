Author: q66 <q66@chimera-linux.org>
Date:   Sat Mar 21 22:45:58 2026 +0100

    disable getgroups fortification for now
    
    This breaks autotools 2.72 checking of getgroups array arguments,
    particularly in C++ with Clang, so disable until investigated and
    proven safe.

diff --git a/include/unistd.h b/include/unistd.h
index a2b3105..d6cc72a 100644
--- a/include/unistd.h
+++ b/include/unistd.h
@@ -31,7 +31,6 @@ extern "C" {
 
 #undef confstr
 #undef getcwd
-#undef getgroups
 #undef gethostname
 #undef getlogin_r
 #undef pread
@@ -75,6 +74,7 @@ _FORTIFY_FN(getdomainname) int getdomainname(char * _FORTIFY_POS0 __s, size_t __
 }
 #endif
 
+#if 0
 _FORTIFY_FN(getgroups) int getgroups(int __l, gid_t * _FORTIFY_POS0 __s)
 {
 	size_t __b = __bos(__s, 0);
@@ -83,6 +83,7 @@ _FORTIFY_FN(getgroups) int getgroups(int __l, gid_t * _FORTIFY_POS0 __s)
 		__builtin_trap();
 	return __orig_getgroups(__l, __s);
 }
+#endif
 
 __fortify_access(write_only, 1, 2)
 _FORTIFY_FN(gethostname) int gethostname(char * _FORTIFY_POS0 __s, size_t __l)
